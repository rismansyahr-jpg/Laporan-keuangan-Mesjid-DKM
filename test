    </div>

    <div class="grid cols-3">
      ${balanceCard('Total Saldo Masjid', totalSaldo, totalChange, 'Gabungan kedua rekening')}
      ${accountSummaryCard('bjb', bjbNow, y, prevM, prevY)}
      ${accountSummaryCard('muamalat', muaNow, y, prevM, prevY)}
    </div>

    <div class="grid cols-2">
      <div class="card">
        <div class="eyebrow">Progres Dana Pembangunan</div>
        <div style="display:flex; align-items:baseline; justify-content:space-between; margin:8px 0 10px;">
          <span class="num" style="font-size:20px; font-weight:700;">${fmtRp(bjbBal)}</span>
