    return `<div style="margin-bottom:11px;">
      <div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:4px;">
        <span>${escapeHtml(cat)}</span>
        <span class="num ${kind==='in'?'amount-in':'amount-out'}">${fmtRp(amt)}</span>
      </div>
      <div class="progress-track" style="height:6px;"><div class="progress-fill" style="width:${pct}%; background:${kind==='in'?'var(--emerald)':'var(--brick)'};"></div></div>
    </div>`;
  }).join('');
}

/* =========================================================
   VIEW: RIWAYAT (full history with filters)
========================================================= */
function renderRiwayat(){
  const f = state.filters;
  let list = [...state.transactions];
  if(f.account!=='all') list = list.filter(t=>t.account===f.account);
  if(f.type!=='all') list = list.filter(t=>t.type===f.type);
  if(f.search.trim()) {
    const q = f.search.trim().toLowerCase();
    list = list.filter(t=> (t.description||'').toLowerCase().includes(q) || (t.category||'').toLowerCase().includes(q) || (t.donor||'').toLowerCase().includes(q));
  }
  list.sort((a,b)=> (b.date+b.createdAt).localeCompare(a.date+a.createdAt));

  const totalIn = list.filter(t=>t.type==='masuk').reduce((s,t)=>s+t.amount,0);
  const totalOut = list.filter(t=>t.type==='keluar').reduce((s,t)=>s+t.amount,0);

  return `
  <div class="eyebrow">Transparansi Kas</div>
  <h2 class="section-title" style="margin-top:4px;">Riwayat Seluruh Transaksi</h2>
  <p class="section-sub">Semua transaksi kedua rekening masjid dapat dilihat oleh jemaah.</p>

  <div class="toolbar">
    <select data-filter="account">
      <option value="all" ${f.account==='all'?'selected':''}>Semua Rekening</option>
      <option value="bjb" ${f.account==='bjb'?'selected':''}>BJB Syariah (Pembangunan)</option>
      <option value="muamalat" ${f.account==='muamalat'?'selected':''}>Bank Muamalat (Operasional)</option>
    </select>
    <select data-filter="type">
      <option value="all" ${f.type==='all'?'selected':''}>Semua Jenis</option>
      <option value="masuk" ${f.type==='masuk'?'selected':''}>Pemasukan</option>
      <option value="keluar" ${f.type==='keluar'?'selected':''}>Pengeluaran</option>
    </select>
    <input type="text" placeholder="Cari keterangan / kategori…" data-filter="search" value="${escapeAttr(f.search)}" style="flex:1; min-width:180px;">
  </div>

  <div class="grid cols-2" style="margin-bottom:14px;">
    <div class="card tight"><div class="eyebrow">Total Pemasukan (hasil filter)</div><div class="num amount-in" style="font-size:19px; font-weight:700; margin-top:4px;">+${fmtRp(totalIn)}</div></div>
