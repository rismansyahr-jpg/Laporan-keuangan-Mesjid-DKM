    <div class="modal proof-modal" onclick="event.stopPropagation()">
      <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
        <div>
          <div style="font-size:13.5px; font-weight:700;">${escapeHtml(t.category)} — ${t.type==='masuk'?'Pemasukan':'Pengeluaran'}</div>
          <div style="font-size:12px; color:var(--muted); margin-top:2px;">${fmtDate(t.date)} · ${accountLabel(t.account)} · <span class="num">${fmtRp(t.amount)}</span></div>
          ${t.description ? `<div style="font-size:12.5px; color:var(--muted); margin-top:4px;">${escapeHtml(t.description)}</div>` : ''}
        </div>
        <button class="btn sm" data-action="close-proof">✕</button>
      </div>
      <img src="${t.proofImage}" alt="Bukti transaksi" style="max-width:100%; border-radius:10px;">
    </div>
  </div>`;
}

/* =========================================================
   ADMIN: INPUT TRANSAKSI MANUAL
========================================================= */
function renderAdminInput(){
  const editing = state.editingId ? state.transactions.find(t=>t.id===state.editingId) : null;
  const acc = editing ? editing.account : 'muamalat';
  const type = editing ? editing.type : 'masuk';
  const cats = CATEGORIES[acc][type];
  return `
  <div class="eyebrow">Bendahara</div>
  <h2 class="section-title" style="margin-top:4px;">${editing ? 'Ubah Transaksi' : 'Input Transaksi Baru'}</h2>
  <p class="section-sub">Catat pemasukan atau pengeluaran secara manual untuk salah satu rekening masjid.</p>

  <div class="card" style="max-width:640px;">
    <form id="tx-form">
      <div class="field-row">
        <div class="field">
          <label>Rekening</label>
          <select name="account" id="f-account">
            <option value="muamalat" ${acc==='muamalat'?'selected':''}>Bank Muamalat — Operasional</option>
            <option value="bjb" ${acc==='bjb'?'selected':''}>BJB Syariah — Pembangunan</option>
          </select>
        </div>
        <div class="field">
          <label>Jenis Transaksi</label>
          <select name="type" id="f-type">
            <option value="masuk" ${type==='masuk'?'selected':''}>Pemasukan</option>
            <option value="keluar" ${type==='keluar'?'selected':''}>Pengeluaran</option>
          </select>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Tanggal</label>
          <input type="date" name="date" value="${editing ? editing.date : new Date().toISOString().slice(0,10)}" required>
        </div>
        <div class="field">
          <label>Jumlah (Rp)</label>
          <input type="number" name="amount" min="0" step="1000" placeholder="0" value="${editing ? editing.amount : ''}" required>
        </div>
      </div>
      <div class="field">
        <label>Kategori</label>
        <select name="category" id="f-category">
          ${cats.map(c=>`<option value="${c}" ${editing && editing.category===c?'selected':''}>${c}</option>`).join('')}
        </select>
      </div>
      <div class="field">
        <label>Keterangan</label>
        <textarea name="description" rows="2" placeholder="Contoh: Infaq shalat Jumat minggu ke-2">${editing ? escapeHtml(editing.description||'') : ''}</textarea>
      </div>
      <div class="field">
        <label>Nama Donatur / Sumber (opsional)</label>
        <input type="text" name="donor" placeholder="Boleh dikosongkan / Hamba Allah" value="${editing ? escapeAttr(editing.donor||'') : ''}">
      </div>
      <div class="field">
        <label>Bukti Transaksi (foto struk/nota — terutama untuk pengeluaran)</label>
        <div id="proof-upload-container">${renderProofUploadBox()}</div>
      </div>
      <div style="display:flex; gap:10px; margin-top:18px;">
        <button type="submit" class="btn primary">${editing ? 'Simpan Perubahan' : 'Simpan Transaksi'}</button>
        ${editing ? `<button type="button" class="btn" data-action="cancel-edit">Batal</button>` : ''}
      </div>
    </form>
  </div>`;
}

function renderProofUploadBox(){
  if(state.tempProofImage){
    return `<div class="proof-preview">
      <img src="${state.tempProofImage}" alt="Pratinjau bukti">
      <button type="button" class="proof-remove" data-action="remove-proof" title="Hapus foto">✕</button>
    </div>
    <div style="font-size:11.5px; color:var(--muted); margin-top:6px;">Foto akan disimpan bersama transaksi ini. Ganti dengan memilih file baru di bawah.</div>
    <div style="margin-top:8px;"><input type="file" id="proof-file" accept="image/*" capture="environment"></div>`;
  }
  return `<div class="proof-upload-box">
    <div style="font-size:24px; margin-bottom:4px;">📎</div>
    <div style="font-size:12.5px; color:var(--muted); margin-bottom:10px;">Ambil foto langsung dari kamera atau unggah file gambar struk/nota</div>
    <input type="file" id="proof-file" accept="image/*" capture="environment">
  </div>`;
}

/* =========================================================
   ADMIN: KELOLA TRANSAKSI
========================================================= */
function renderAdminKelola(){
  const f = state.filters;
  let list = [...state.transactions];
  if(f.account!=='all') list = list.filter(t=>t.account===f.account);
  if(f.type!=='all') list = list.filter(t=>t.type===f.type);
  if(f.search.trim()){
    const q = f.search.trim().toLowerCase();
    list = list.filter(t=> (t.description||'').toLowerCase().includes(q) || (t.category||'').toLowerCase().includes(q));
  }
  list.sort((a,b)=> (b.date+b.createdAt).localeCompare(a.date+a.createdAt));

  return `
  <div class="eyebrow">Bendahara</div>
  <h2 class="section-title" style="margin-top:4px;">Kelola Transaksi</h2>
  <p class="section-sub">Ubah atau hapus transaksi yang sudah tercatat. Total ${state.transactions.length} transaksi.</p>

  <div class="toolbar">
    <select data-filter="account">
      <option value="all" ${f.account==='all'?'selected':''}>Semua Rekening</option>
      <option value="bjb" ${f.account==='bjb'?'selected':''}>BJB Syariah</option>
      <option value="muamalat" ${f.account==='muamalat'?'selected':''}>Bank Muamalat</option>
    </select>
    <select data-filter="type">
      <option value="all" ${f.type==='all'?'selected':''}>Semua Jenis</option>
      <option value="masuk" ${f.type==='masuk'?'selected':''}>Pemasukan</option>
      <option value="keluar" ${f.type==='keluar'?'selected':''}>Pengeluaran</option>
    </select>
    <input type="text" placeholder="Cari…" data-filter="search" value="${escapeAttr(f.search)}" style="flex:1; min-width:160px;">
    <button class="btn primary" data-action="nav" data-view="admin-input">+ Transaksi Baru</button>
  </div>

  <div class="card" style="padding:0;">
    ${list.length===0 ? emptyState('Tidak ada transaksi.') : `
    <div style="overflow-x:auto;"><table>
      <thead><tr><th>Tanggal</th><th>Rekening</th><th>Jenis</th><th>Kategori</th><th>Keterangan</th><th class="t-right">Jumlah</th><th>Bukti</th><th></th></tr></thead>
      <tbody>
      ${list.map(t=>`<tr>
        <td>${fmtDate(t.date)}</td>
        <td>${t.account==='bjb'?'<span class="pill bjb">BJB</span>':'<span class="pill muamalat">Muamalat</span>'}</td>
        <td>${t.type==='masuk'?'Masuk':'Keluar'}</td>
        <td>${escapeHtml(t.category)}</td>
        <td style="color:var(--muted); max-width:200px;">${escapeHtml(t.description||'-')}</td>
        <td class="t-right num ${t.type==='masuk'?'amount-in':'amount-out'}">${t.type==='masuk'?'+':'-'}${fmtRp(t.amount)}</td>
        <td>${proofButton(t)}</td>
        <td>
          <div style="display:flex; gap:6px;">
            <button class="btn sm" data-action="edit-tx" data-id="${t.id}">Ubah</button>
            <button class="btn sm danger" data-action="delete-tx" data-id="${t.id}">Hapus</button>
          </div>
        </td>
      </tr>`).join('')}
      </tbody>
    </table></div>`}
  </div>`;
}

/* =========================================================
   ADMIN: IMPORT & SETTINGS (STUBS)
========================================================= */
function renderAdminImport(){
  return `<div class="eyebrow">Bendahara</div><h2 class="section-title">Impor Transaksi</h2><p class="section-sub">Fitur impor CSV akan segera tersedia.</p><div class="card"><p style="color:var(--muted);">Halaman ini sedang dalam pengembangan.</p></div>`;
}

function renderAdminSettings(){
  return `<div class="eyebrow">Bendahara</div><h2 class="section-title">Pengaturan</h2><p class="section-sub">Kelola konfigurasi sistem masjid.</p><div class="card"><p style="color:var(--muted);">Halaman pengaturan sedang dalam pengembangan.</p></div>`;
}

/* =========================================================
   EVENT HANDLERS
========================================================= */
function attachGlobalHandlers(){
  document.addEventListener('click', handleClick);
  document.addEventListener('change', handleChange);
  document.addEventListener('submit', handleSubmit);
}

function handleClick(e){
  const btn = e.target.closest('[data-action]');
  if(!btn) return;
  const action = btn.dataset.action;
  
  if(action==='nav') state.view = btn.dataset.view;
  if(action==='set-role') {
    const role = btn.dataset.role;
    if(role==='admin' && !state.isAdmin) {
      state.showPinModal = true;
    } else if(role==='jemaah') {
      state.isAdmin = false;
    }
  }
  if(action==='close-modal-bg' || action==='close-modal') state.showPinModal = false;
  if(action==='submit-pin') {
    const pinInput = document.getElementById('pin-input');
    if(pinInput && pinInput.value === state.settings.adminPin) {
      state.isAdmin = true;
      state.showPinModal = false;
      state.pinInput = '';
      state.pinError = '';
    } else {
      state.pinError = 'PIN salah.';
    }
  }
  if(action==='close-proof-bg' || action==='close-proof') state.viewingProofId = null;
  if(action==='view-proof') state.viewingProofId = btn.dataset.id;
  if(action==='remove-proof') state.tempProofImage = null;
  if(action==='edit-tx') {
    state.editingId = btn.dataset.id;
    state.view = 'admin-input';
  }
  if(action==='delete-tx') {
    if(confirm('Hapus transaksi ini?')) {
      state.transactions = state.transactions.filter(t=>t.id!==btn.dataset.id);
      persistTransactions();
    }
  }
  if(action==='cancel-edit') state.editingId = null;
  if(action==='print-report') window.print();
  
  render();
}

function handleChange(e){
  const sel = e.target;
  if(sel.dataset && sel.dataset.filter) {
    state.filters[sel.dataset.filter] = sel.value;
    render();
  }
  if(sel.id && sel.id.startsWith('rep-')) {
    const key = sel.id.slice(4);
    state.reportFilters[key] = sel.value;
    render();
  }
  if(sel.id==='f-account' || sel.id==='f-type') {
    const acc = document.getElementById('f-account').value;
    const type = document.getElementById('f-type').value;
    const catSel = document.getElementById('f-category');
    if(catSel) {
      const cats = CATEGORIES[acc][type];
      catSel.innerHTML = cats.map(c=>`<option value="${c}">${c}</option>`).join('');
    }
  }
  if(sel.id==='proof-file') {
    const file = sel.files[0];
    if(file) {
      const reader = new FileReader();
      reader.onload = (ev)=>{ state.tempProofImage = ev.target.result; render(); };
      reader.readAsDataURL(file);
    }
  }
}

function handleSubmit(e){
  if(e.target.id==='tx-form') {
    e.preventDefault();
    const fd = new FormData(e.target);
    const tx = {
      id: state.editingId || uid(),
      date: fd.get('date'),
      account: fd.get('account'),
      type: fd.get('type'),
      category: fd.get('category'),
      amount: Number(fd.get('amount')),
      description: fd.get('description'),
      donor: fd.get('donor'),
      proofImage: state.tempProofImage || null,
      createdAt: Date.now()
    };
    
    if(state.editingId) {
      const idx = state.transactions.findIndex(t=>t.id===state.editingId);
      if(idx>=0) state.transactions[idx] = tx;
    } else {
      state.transactions.push(tx);
    }
    
    persistTransactions();
    state.editingId = null;
    state.tempProofImage = null;
    state.view = 'dashboard';
    showToast(state.editingId ? 'Transaksi diperbarui.' : 'Transaksi tersimpan.');
    render();
  }
}

/* =========================================================
   INITIALIZATION
========================================================= */
window.addEventListener('DOMContentLoaded', loadData);
</script>
