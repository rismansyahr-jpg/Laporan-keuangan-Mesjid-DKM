function balanceCard(title, amount, change, sub){
  const badge = change>0.001 ? `<span class="badge up">▲ ${change.toFixed(1)}%</span>` : change<-0.001 ? `<span class="badge down">▼ ${Math.abs(change).toFixed(1)}%</span>` : `<span class="badge flat">– stabil</span>`;
  return `<div class="card balance-card">
    <div class="eyebrow">${title}</div>
    <div class="amount num ${amount<0?'negative':''}">${fmtRp(amount)}</div>
    <div style="display:flex; align-items:center; gap:8px; margin-top:6px;">
      ${badge}
      <span style="font-size:12px; color:var(--muted);">${sub} vs bulan lalu</span>
    </div>
  </div>`;
}

