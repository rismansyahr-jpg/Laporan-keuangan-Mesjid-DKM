<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Laporan Keuangan Masjid</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#2B1330;
    --muted:#7C6683;
    --paper:#FAF7FB;
    --panel:#FFFFFF;
    --panel-2:#F5EDF6;
    --emerald:#6B2168;
    --emerald-deep:#3E1240;
    --emerald-tint:#F0E3F0;
    --gold:#C23B92;
    --gold-tint:#F7E4F1;
    --brick:#9C2E5C;
    --brick-tint:#F5E2EA;
    --line:#E7D9E9;
    --line-strong:#D3BCD8;
    --shadow: 0 1px 2px rgba(43,19,48,0.05), 0 8px 24px -12px rgba(43,19,48,0.22);
    --radius: 14px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--paper);
    color:var(--ink);
    font-family:'Inter',system-ui,sans-serif;
    -webkit-font-smoothing:antialiased;
    min-height:100vh;
  }
  .num{font-family:'JetBrains Mono', monospace; font-variant-numeric:tabular-nums; letter-spacing:-0.02em;}
  h1,h2,h3,.display{font-family:'Fraunces', serif;}
  a{color:inherit;}
  button{font-family:inherit;cursor:pointer;}
  ::selection{background:var(--gold-tint);}

  /* ---------- Layout shell ---------- */
  #app{min-height:100vh; display:flex; flex-direction:column;}
  .wrap{max-width:1180px; margin:0 auto; padding:0 24px;}
  @media (max-width:640px){ .wrap{padding:0 16px;} }

  header.top{
    background:linear-gradient(180deg, var(--emerald-deep) 0%, var(--emerald) 100%);
    color:#F6F1E7;
    position:relative;
    overflow:hidden;
  }
  .top-inner{
    display:flex; align-items:center; justify-content:space-between;
    padding:22px 0 18px;
    position:relative; z-index:2;
    flex-wrap:wrap; gap:14px;
  }
  .brand{display:flex; align-items:center; gap:14px;}
  .brand-mark{
    width:50px;height:50px;border-radius:50%;
    background:#fff;
    display:flex;align-items:center;justify-content:center;
    border:2px solid rgba(246,241,231,0.55);
    flex-shrink:0;
    overflow:hidden;
    box-shadow:0 2px 8px rgba(0,0,0,0.18);
  }
  .brand-mark img{width:100%; height:100%; object-fit:cover;}
  .brand-name{font-size:20px; font-weight:600; line-height:1.15;}
  .brand-tag{font-size:12.5px; opacity:0.72; margin-top:2px; font-weight:400;}
  .role-switch{display:flex; gap:6px; background:rgba(0,0,0,0.18); padding:4px; border-radius:999px; border:1px solid rgba(246,241,231,0.18);}
  .role-btn{
    border:none; background:transparent; color:#F6F1E7; opacity:0.65;
    padding:8px 16px; border-radius:999px; font-size:13.5px; font-weight:600;
    transition:all .15s ease;
  }
  .role-btn.active{background:#F6F1E7; color:var(--emerald-deep); opacity:1;}
  .role-btn:not(.active):hover{opacity:0.9;}

  .geo-band{width:100%; height:34px; display:block; position:relative; z-index:1;}

  nav.tabs{
    background:var(--panel);
    border-bottom:1px solid var(--line);
    position:sticky; top:0; z-index:30;
  }
  .tabs-inner{display:flex; gap:4px; overflow-x:auto; padding:0; }
  .tab-btn{
    border:none; background:transparent; padding:15px 16px; font-size:13.5px; font-weight:600;
    color:var(--muted); white-space:nowrap; border-bottom:2.5px solid transparent; margin-bottom:-1px;
    transition:color .15s ease, border-color .15s ease;
  }
  .tab-btn:hover{color:var(--ink);}
  .tab-btn.active{color:var(--emerald-deep); border-bottom-color:var(--gold);}
  .tab-sep{width:1px; background:var(--line); margin:10px 4px; flex-shrink:0;}

  main{flex:1; padding:28px 0 60px;}
  footer.site-footer{border-top:1px solid var(--line); padding:22px 0; font-size:12.5px; color:var(--muted); text-align:center;}

  /* ---------- Cards / generic ---------- */
  .grid{display:grid; gap:16px;}
  .cols-3{grid-template-columns:repeat(3,1fr);}
  .cols-2{grid-template-columns:repeat(2,1fr);}
  @media (max-width:860px){ .cols-3{grid-template-columns:1fr;} .cols-2{grid-template-columns:1fr;} }

  .card{
    background:var(--panel); border:1px solid var(--line); border-radius:var(--radius);
    padding:20px; box-shadow:var(--shadow);
  }
  .card.tight{padding:16px;}
  .eyebrow{font-size:11px; letter-spacing:0.09em; text-transform:uppercase; color:var(--muted); font-weight:700;}
  .section-title{font-size:20px; font-weight:600; margin:0 0 4px;}
  .section-sub{font-size:13.5px; color:var(--muted); margin:0 0 18px;}

  .balance-card{position:relative; overflow:hidden;}
  .balance-card .amount{font-size:28px; font-weight:700; margin:6px 0 2px;}
  .balance-card .amount.negative{color:var(--brick);}
  .badge{
    display:inline-flex; align-items:center; gap:5px; font-size:12px; font-weight:700;
    padding:3px 9px; border-radius:999px;
  }
  .badge.up{background:var(--emerald-tint); color:var(--emerald-deep);}
  .badge.down{background:var(--brick-tint); color:var(--brick);}
  .badge.flat{background:var(--gold-tint); color:var(--gold);}
  .mini-row{display:flex; justify-content:space-between; font-size:13px; padding:8px 0; border-top:1px solid var(--line);}
  .mini-row:first-of-type{border-top:none; margin-top:12px;}
  .mini-row .lbl{color:var(--muted);}
  .mini-row .val.in{color:var(--emerald-deep); font-weight:600;}
  .mini-row .val.out{color:var(--brick); font-weight:600;}

  .pill{display:inline-block; padding:2px 10px; border-radius:999px; font-size:11.5px; font-weight:700;}
  .pill.bjb{background:var(--gold-tint); color:#8A2E6E;}
  .pill.muamalat{background:var(--emerald-tint); color:var(--emerald-deep);}

  .btn{
    border:1px solid var(--line-strong); background:var(--panel); color:var(--ink);
    padding:9px 16px; border-radius:9px; font-size:13.5px; font-weight:600;
    transition:all .15s ease; display:inline-flex; align-items:center; gap:6px;
  }
  .btn:hover{border-color:var(--emerald); color:var(--emerald-deep);}
  .btn.primary{background:var(--emerald); border-color:var(--emerald); color:#fff;}
  .btn.primary:hover{background:var(--emerald-deep);}
  .btn.danger{color:var(--brick); border-color:var(--brick-tint);}
  .btn.danger:hover{background:var(--brick-tint); border-color:var(--brick);}
  .btn.sm{padding:6px 11px; font-size:12.5px;}
  .btn:disabled{opacity:0.45; cursor:not-allowed;}

  table{width:100%; border-collapse:collapse; font-size:13.5px;}
  th{text-align:left; font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:var(--muted); font-weight:700; padding:10px 12px; border-bottom:1.5px solid var(--line-strong); white-space:nowrap;}
  td{padding:11px 12px; border-bottom:1px solid var(--line); vertical-align:top;}
  tr:hover td{background:var(--panel-2);}
  .t-right{text-align:right;}
  .amount-in{color:var(--emerald-deep); font-weight:600;}
  .amount-out{color:var(--brick); font-weight:600;}

  .empty{text-align:center; padding:48px 20px; color:var(--muted);}
  .empty .icon{font-size:32px; margin-bottom:10px; opacity:0.5;}

  input,select,textarea{
    font-family:inherit; font-size:13.5px; padding:9px 11px; border-radius:9px;
    border:1px solid var(--line-strong); background:var(--panel); color:var(--ink); width:100%;
  }
  input:focus,select:focus,textarea:focus{outline:2px solid var(--emerald); outline-offset:1px; border-color:var(--emerald);}
  label{font-size:12.5px; font-weight:600; color:var(--muted); display:block; margin-bottom:5px;}
  .field{margin-bottom:14px;}
  .field-row{display:grid; grid-template-columns:1fr 1fr; gap:12px;}
  @media (max-width:640px){.field-row{grid-template-columns:1fr;}}

  .toolbar{display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-bottom:16px;}
  .toolbar select, .toolbar input{width:auto; min-width:120px;}

  .modal-bg{position:fixed; inset:0; background:rgba(62,18,64,0.5); display:flex; align-items:center; justify-content:center; z-index:100; padding:20px;}
  .modal{background:var(--panel); border-radius:var(--radius); padding:26px; max-width:380px; width:100%; box-shadow:0 20px 60px -10px rgba(0,0,0,0.35);}
  .modal.proof-modal{max-width:520px; padding:18px;}
  .modal.proof-modal img{width:100%; border-radius:10px; display:block; border:1px solid var(--line);}

  .proof-link{display:inline-flex; align-items:center; gap:4px; font-size:12px; font-weight:600; color:var(--emerald); background:var(--emerald-tint); padding:4px 9px; border-radius:999px; border:none;}
  .proof-link:hover{background:var(--gold-tint); color:var(--emerald-deep);}
  .proof-none{font-size:12px; color:var(--muted); opacity:0.55;}

  .proof-upload-box{border:1.5px dashed var(--line-strong); border-radius:12px; padding:16px; text-align:center; background:var(--panel-2);}
  .proof-preview{position:relative; display:inline-block; margin-top:10px;}
  .proof-preview img{max-width:220px; max-height:220px; border-radius:10px; border:1px solid var(--line); display:block;}
  .proof-remove{position:absolute; top:-8px; right:-8px; background:var(--brick); color:#fff; border:2px solid #fff; width:24px; height:24px; border-radius:50%; font-size:13px; line-height:1; display:flex; align-items:center; justify-content:center;}

  .progress-track{height:10px; background:var(--panel-2); border-radius:999px; overflow:hidden; border:1px solid var(--line);}
  .progress-fill{height:100%; background:linear-gradient(90deg, var(--gold), var(--emerald)); border-radius:999px;}

  .toast{position:fixed; bottom:22px; left:50%; transform:translateX(-50%); background:var(--emerald-deep); color:#fff; padding:11px 20px; border-radius:10px; font-size:13.5px; font-weight:600; box-shadow:var(--shadow); z-index:200;}

  .chart-wrap{overflow-x:auto;}
  .legend{display:flex; gap:16px; font-size:12.5px; color:var(--muted); margin-top:8px;}
  .legend span{display:inline-flex; align-items:center; gap:6px;}
  .dot{width:9px;height:9px;border-radius:3px;display:inline-block;}

  @media print{
    header.top, nav.tabs, footer.site-footer, .no-print{display:none !important;}
    body{background:#fff;}
    main{padding:0;}
    .card{box-shadow:none; border:1px solid #ccc;}
  }
</style>
</head>
<body>
<div id="app"></div>

<script>
/* =========================================================
   DATA MODEL & DEFAULTS
========================================================= */
const STORAGE_KEY_TX = 'masjid:transactions';
const STORAGE_KEY_SETTINGS = 'masjid:settings';

const DEFAULT_SETTINGS = {
  mosqueName: "DKM Cluster Amethyst",
  tagline: "Transparansi & Akuntabilitas Keuangan Jemaah",
  accounts: {
    bjb: { label: "BJB Syariah", purpose: "Dana Pembangunan Masjid", number: "0012345678", holder: "DKM Masjid Al-Ikhlas" },
    muamalat: { label: "Bank Muamalat", purpose: "Kas Operasional Masjid", number: "9876543210", holder: "DKM Masjid Al-Ikhlas" }
  },
  pembangunanTarget: 500000000,
  adminPin: "masjid123"
};

const CATEGORIES = {
  bjb: {
    masuk: ["Donasi Pembangunan", "Wakaf Pembangunan", "Sumbangan CSR/Perusahaan", "Pencairan Proposal", "Lain-lain"],
    keluar: ["Material Bangunan", "Upah Tukang", "Sewa Alat", "Konsultan/Gambar", "Perizinan", "Lain-lain"]
  },
  muamalat: {
    masuk: ["Infaq Jumat", "Sedekah Umum", "Donasi Kotak Amal", "Zakat", "Wakaf Tunai", "Hasil Usaha Masjid", "Lain-lain"],
    keluar: ["Listrik", "Air", "Kebersihan", "Honor Marbot/Imam", "Perawatan & Perbaikan", "Kegiatan Dakwah", "ATK & Perlengkapan", "Konsumsi Kegiatan", "Lain-lain"]
  }
};

const MONTHS = ["Januari","Februari","Maret","April","Mei","Juni","Juli","Agustus","September","Oktober","November","Desember"];

let state = {
  view: 'dashboard',
  isAdmin: false,
  loading: true,
  transactions: [],
  settings: JSON.parse(JSON.stringify(DEFAULT_SETTINGS)),
  filters: { account:'all', type:'all', category:'all', search:'', month: new Date().getMonth(), year: new Date().getFullYear() },
  reportFilters: { account:'muamalat', month: new Date().getMonth(), year: new Date().getFullYear() },
  editingId: null,
  showPinModal: false,
  pinInput: '',
  pinError: '',
  toast: null,
  csvPreview: null,
  viewingProofId: null,
  tempProofImage: null,
};

/* =========================================================
   STORAGE HELPERS (persistent, shared across all visitors)
========================================================= */
async function loadData(){
  try{
    const tx = await window.storage.get(STORAGE_KEY_TX, true);
    state.transactions = tx ? JSON.parse(tx.value) : sampleTransactions();
  }catch(e){ state.transactions = sampleTransactions(); }
  try{
    const s = await window.storage.get(STORAGE_KEY_SETTINGS, true);
    state.settings = s ? JSON.parse(s.value) : JSON.parse(JSON.stringify(DEFAULT_SETTINGS));
  }catch(e){ state.settings = JSON.parse(JSON.stringify(DEFAULT_SETTINGS)); }
  if(!state.transactions || state.transactions.length===0){
    state.transactions = sampleTransactions();
    await persistTransactions();
  }
  state.loading = false;
  render();
}

async function persistTransactions(){
  try{ await window.storage.set(STORAGE_KEY_TX, JSON.stringify(state.transactions), true); }
  catch(e){ showToast('Gagal menyimpan data. Coba lagi.'); }
}
async function persistSettings(){
  try{ await window.storage.set(STORAGE_KEY_SETTINGS, JSON.stringify(state.settings), true); }
  catch(e){ showToast('Gagal menyimpan pengaturan.'); }
}

function sampleTransactions(){
  const today = new Date();
  const y = today.getFullYear(), m = today.getMonth();
  const d = (mm,dd)=> new Date(y, mm, dd).toISOString().slice(0,10);
  return [
    {id:uid(), date:d(m,3), account:'muamalat', type:'masuk', category:'Infaq Jumat', amount:4250000, description:'Infaq shalat Jumat', donor:'', createdAt:Date.now()},
    {id:uid(), date:d(m,5), account:'muamalat', type:'keluar', category:'Listrik', amount:850000, description:'Tagihan listrik bulan berjalan', donor:'', createdAt:Date.now()},
    {id:uid(), date:d(m,7), account:'muamalat', type:'keluar', category:'Honor Marbot/Imam', amount:2500000, description:'Honor marbot & imam', donor:'', createdAt:Date.now()},
    {id:uid(), date:d(m,10), account:'bjb', type:'masuk', category:'Donasi Pembangunan', amount:15000000, description:'Donasi renovasi lantai 2', donor:'Hamba Allah', createdAt:Date.now()},
    {id:uid(), date:d(m,12), account:'bjb', type:'keluar', category:'Material Bangunan', amount:8200000, description:'Pembelian semen & besi', donor:'', createdAt:Date.now()},
    {id:uid(), date:d(m-1,20), account:'muamalat', type:'masuk', category:'Sedekah Umum', amount:3100000, description:'Kotak amal bulan lalu', donor:'', createdAt:Date.now()},
    {id:uid(), date:d(m-1,22), account:'muamalat', type:'keluar', category:'Kebersihan', amount:600000, description:'Alat kebersihan masjid', donor:'', createdAt:Date.now()},
    {id:uid(), date:d(m-1,15), account:'bjb', type:'masuk', category:'Wakaf Pembangunan', amount:22000000, description:'Wakaf tunai jemaah', donor:'Hamba Allah', createdAt:Date.now()},
  ];
}
function uid(){ return 'tx_' + Math.random().toString(36).slice(2,10) + Date.now().toString(36); }

/* =========================================================
   FORMATTERS & CALCULATIONS
========================================================= */
function fmtRp(n){
  const v = Math.round(Number(n)||0);
  return 'Rp ' + v.toLocaleString('id-ID');
}
function fmtDate(iso){
  const d = new Date(iso+'T00:00:00');
  return d.toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'});
}
function accountLabel(acc){ return state.settings.accounts[acc]?.label || acc; }

function txForAccount(acc){ return state.transactions.filter(t=>t.account===acc); }

function balanceAt(acc, dateStr /* inclusive, YYYY-MM-DD */){
  return txForAccount(acc)
    .filter(t=> t.date <= dateStr)
    .reduce((s,t)=> s + (t.type==='masuk' ? t.amount : -t.amount), 0);
}
function currentBalance(acc){
  const todayStr = new Date().toISOString().slice(0,10);
  return balanceAt(acc, '9999-12-31'); // all recorded tx regardless of future/past
}
function monthRange(year, month){
  const first = new Date(year, month, 1).toISOString().slice(0,10);
  const last = new Date(year, month+1, 0).toISOString().slice(0,10);
  return {first, last};
}
function monthSummary(acc, year, month){
  const {first, last} = monthRange(year, month);
  const txs = txForAccount(acc).filter(t=> t.date>=first && t.date<=last);
  const income = txs.filter(t=>t.type==='masuk').reduce((s,t)=>s+t.amount,0);
  const expense = txs.filter(t=>t.type==='keluar').reduce((s,t)=>s+t.amount,0);
  const prevDay = new Date(year, month, 1); prevDay.setDate(prevDay.getDate()-1);
  const saldoAwal = balanceAt(acc, prevDay.toISOString().slice(0,10));
  const saldoAkhir = saldoAwal + income - expense;
  return {income, expense, saldoAwal, saldoAkhir, count: txs.length, txs};
}
function pctChange(curr, prev){
  if(prev===0) return curr===0 ? 0 : 100;
  return ((curr-prev)/Math.abs(prev))*100;
}
function categoryBreakdown(acc, year, month, type){
  const {txs} = monthSummary(acc, year, month);
  const filtered = txs.filter(t=>t.type===type);
  const map = {};
  filtered.forEach(t=> map[t.category] = (map[t.category]||0) + t.amount);
  return Object.entries(map).sort((a,b)=>b[1]-a[1]);
}
function last6MonthsData(acc){
  const now = new Date();
  const out = [];
  for(let i=5;i>=0;i--){
    const d = new Date(now.getFullYear(), now.getMonth()-i, 1);
    const s = monthSummary(acc, d.getFullYear(), d.getMonth());
    out.push({label: MONTHS[d.getMonth()].slice(0,3)+' '+String(d.getFullYear()).slice(2), income:s.income, expense:s.expense});
  }
  return out;
}

/* =========================================================
   RENDER: ROOT
========================================================= */
function render(){
  const app = document.getElementById('app');
  if(state.loading){
    app.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;min-height:100vh;color:var(--muted);font-size:14px;">Memuat data laporan keuangan…</div>`;
    return;
  }
  app.innerHTML = `
    ${renderHeader()}
    ${renderTabs()}
    <main><div class="wrap">${renderView()}</div></main>
    ${renderFooter()}
    ${state.showPinModal ? renderPinModal() : ''}
    ${state.viewingProofId ? renderProofModal() : ''}
    ${state.toast ? `<div class="toast">${state.toast}</div>` : ''}
  `;
  attachGlobalHandlers();
}

function renderHeader(){
  const s = state.settings;
  return `
  <header class="top">
    <div class="wrap top-inner">
      <div class="brand">
        <div class="brand-mark"><img src="data:image/webp;base64," alt="Logo DKM Cluster Amethyst"></div>
        <div>
          <div class="brand-name">${escapeHtml(s.mosqueName)}</div>
          <div class="brand-tag">${escapeHtml(s.tagline)}</div>
        </div>
      </div>
      <div class="role-switch">
        <button class="role-btn ${!state.isAdmin?'active':''}" data-action="set-role" data-role="jemaah">Jemaah</button>
        <button class="role-btn ${state.isAdmin?'active':''}" data-action="set-role" data-role="admin">Admin / Bendahara</button>
      </div>
    </div>
    ${geoBand()}
  </header>`;
}

function starSVG(size){
  return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none">
    <path d="M12 2 L14.3 9.2 L21.8 9.2 L15.7 13.8 L18 21 L12 16.4 L6 21 L8.3 13.8 L2.2 9.2 L9.7 9.2 Z" stroke="#F6F1E7" stroke-width="1.1" stroke-linejoin="round"/>
  </svg>`;
}
function geoBand(){
  return `<svg class="geo-band" viewBox="0 0 1180 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id="geoPattern" width="34" height="34" patternUnits="userSpaceOnUse">
        <path d="M17 1 L33 17 L17 33 L1 17 Z M17 9 L25 17 L17 25 L9 17 Z" fill="none" stroke="#F6F1E7" stroke-width="1" opacity="0.16"/>
      </pattern>
    </defs>
    <rect width="1180" height="34" fill="url(#geoPattern)"/>
  </svg>`;
}

function renderTabs(){
  const jemaahTabs = [
    {id:'dashboard', label:'Ringkasan'},
    {id:'bjb', label:'Rek. BJB Syariah'},
    {id:'muamalat', label:'Rek. Bank Muamalat'},
    {id:'riwayat', label:'Riwayat Transaksi'},
    {id:'laporan', label:'Laporan Bulanan'},
  ];
  const adminTabs = [
    {id:'admin-input', label:'+ Input Transaksi'},
    {id:'admin-kelola', label:'Kelola Transaksi'},
    {id:'admin-import', label:'Impor File'},
    {id:'admin-settings', label:'Pengaturan'},
  ];
  const items = jemaahTabs.map(t=>`<button class="tab-btn ${state.view===t.id?'active':''}" data-action="nav" data-view="${t.id}">${t.label}</button>`).join('');
  const adminItems = state.isAdmin ? `<div class="tab-sep"></div>` + adminTabs.map(t=>`<button class="tab-btn ${state.view===t.id?'active':''}" data-action="nav" data-view="${t.id}">${t.label}</button>`).join('') : '';
  return `<nav class="tabs"><div class="wrap tabs-inner">${items}${adminItems}</div></nav>`;
}

function renderFooter(){
  return `<footer class="site-footer no-print">
