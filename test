function barChart(data){
  const w = 900, h = 190, padL=40, padB=28, padT=10;
  const maxVal = Math.max(1, ...data.flatMap(d=>[d.income, d.expense]));
  const groupW = (w-padL-10)/data.length;
  const barW = Math.min(26, groupW/3.2);
  let bars = '';
  data.forEach((d,i)=>{
    const gx = padL + i*groupW + groupW/2;
    const hIn = (d.income/maxVal)*(h-padT-padB);
    const hOut = (d.expense/maxVal)*(h-padT-padB);
    const yIn = h-padB-hIn, yOut = h-padB-hOut;
    bars += `<rect x="${gx-barW-2}" y="${yIn}" width="${barW}" height="${hIn}" rx="3" fill="var(--emerald)"></rect>`;
    bars += `<rect x="${gx+2}" y="${yOut}" width="${barW}" height="${hOut}" rx="3" fill="var(--brick)"></rect>`;
    bars += `<text x="${gx}" y="${h-8}" text-anchor="middle" font-size="10.5" fill="#6B6153">${d.label}</text>`;
  });
  const grid = `<line x1="${padL}" y1="${h-padB}" x2="${w-6}" y2="${h-padB}" stroke="#DCD4C0" stroke-width="1"/>`;
  return `<div class="chart-wrap"><svg viewBox="0 0 ${w} ${h}" width="100%" style="min-width:560px; height:${h}px; font-family:Inter;">
    <style>text{fill:var(--muted);}</style>
    ${grid}${bars}
  </svg></div>
  <div class="legend"><span><i class="dot" style="background:var(--emerald);"></i>Pemasukan</span><span><i class="dot" style="background:var(--brick);"></i>Pengeluaran</span></div>`;
}

