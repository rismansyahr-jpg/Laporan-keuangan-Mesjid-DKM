}

function downloadCsvTemplate(){
  const csv = "tanggal,rekening,jenis,kategori,jumlah,keterangan,donatur\n2026-07-01,muamalat,masuk,Infaq Jumat,3500000,Infaq shalat Jumat,\n2026-07-03,muamalat,keluar,Listrik,750000,Tagihan listrik,\n2026-07-05,bjb,masuk,Donasi Pembangunan,10000000,Donasi renovasi,Hamba Allah\n";
  const blob = new Blob([csv], {type:'text/csv'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'template-transaksi-masjid.csv';
  a.click();
  URL.revokeObjectURL(url);
}

function parseCsv(text){
  const lines = text.split(/\r?\n/).filter(l=>l.trim().length>0);
  if(lines.length<2){ showToast('File CSV kosong atau tidak valid.'); return; }
  const header = lines[0].split(',').map(h=>h.trim().toLowerCase());
  const idx = {
    date: header.indexOf('tanggal'), account: header.indexOf('rekening'), type: header.indexOf('jenis'),
    category: header.indexOf('kategori'), amount: header.indexOf('jumlah'), description: header.indexOf('keterangan'),
    donor: header.indexOf('donatur')
  };
  if(idx.date<0 || idx.account<0 || idx.type<0 || idx.amount<0){
    showToast('Kolom wajib (tanggal, rekening, jenis, jumlah) tidak ditemukan.');
    return;
  }
  const valid = []; const errors = [];
  for(let i=1;i<lines.length;i++){
    const cols = lines[i].split(',');
    const rowNum = i+1;
    const date = (cols[idx.date]||'').trim();
    const account = (cols[idx.account]||'').trim().toLowerCase();
    const type = (cols[idx.type]||'').trim().toLowerCase();
    const category = idx.category>=0 ? (cols[idx.category]||'').trim() : 'Lain-lain';
    const amount = Number((cols[idx.amount]||'').trim());
    const description = idx.description>=0 ? (cols[idx.description]||'').trim() : '';
    const donor = idx.donor>=0 ? (cols[idx.donor]||'').trim() : '';

    if(!/^\d{4}-\d{2}-\d{2}$/.test(date)){ errors.push({row:rowNum, msg:'format tanggal harus YYYY-MM-DD'}); continue; }
    if(account!=='bjb' && account!=='muamalat'){ errors.push({row:rowNum, msg:'rekening harus "bjb" atau "muamalat"'}); continue; }
    if(type!=='masuk' && type!=='keluar'){ errors.push({row:rowNum, msg:'jenis harus "masuk" atau "keluar"'}); continue; }
    if(!amount || amount<=0){ errors.push({row:rowNum, msg:'jumlah tidak valid'}); continue; }

    valid.push({ id: uid(), date, account, type, category: category||'Lain-lain', amount, description, donor, createdAt: Date.now() });
  }
  state.csvPreview = {valid, errors};
  render();
}

function confirmImport(){
  if(!state.csvPreview || state.csvPreview.valid.length===0) return;
  state.transactions.push(...state.csvPreview.valid);
  persistTransactions();
  const count = state.csvPreview.valid.length;
  state.csvPreview = null;
  render();
  showToast(`${count} transaksi berhasil diimpor.`);
}

