/* =========================================================
   EVENT HANDLING
========================================================= */
function showToast(msg){
  state.toast = msg;
  render();
  setTimeout(()=>{ state.toast=null; render(); }, 2600);
}
function escapeHtml(str){
  return String(str??'').replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function escapeAttr(str){ return escapeHtml(str); }

function attachGlobalHandlers(){
  const app = document.getElementById('app');

  app.querySelectorAll('[data-action]').forEach(el=>{
    el.addEventListener('click', (e)=>{
      const action = el.getAttribute('data-action');
      if(action==='set-role'){
        const role = el.getAttribute('data-role');
        if(role==='admin' && !state.isAdmin){ state.showPinModal = true; state.pinInput=''; state.pinError=''; render(); }
        else if(role==='jemaah'){ state.isAdmin=false; state.view='dashboard'; render(); }
      }
      if(action==='nav'){ state.view = el.getAttribute('data-view'); state.editingId=null; state.tempProofImage=null; window.scrollTo({top:0,behavior:'smooth'}); render(); }
      if(action==='close-modal' || action==='close-modal-bg'){ if(e.target===el){ state.showPinModal=false; render(); } }
      if(action==='submit-pin'){ submitPin(); }
      if(action==='edit-tx'){
        state.editingId = el.getAttribute('data-id');
        const tx = state.transactions.find(t=>t.id===state.editingId);
        state.tempProofImage = tx ? (tx.proofImage||null) : null;
        state.view='admin-input'; window.scrollTo({top:0}); render();
      }
      if(action==='cancel-edit'){ state.editingId=null; state.tempProofImage=null; render(); }
      if(action==='delete-tx'){ deleteTx(el.getAttribute('data-id')); }
      if(action==='print-report'){ window.print(); }
      if(action==='download-template'){ downloadCsvTemplate(); }
      if(action==='confirm-import'){ confirmImport(); }
      if(action==='cancel-import'){ state.csvPreview=null; render(); }
      if(action==='view-proof'){ state.viewingProofId = el.getAttribute('data-id'); render(); }
      if(action==='close-proof' || action==='close-proof-bg'){ if(e.target===el){ state.viewingProofId=null; render(); } }
      if(action==='remove-proof'){ state.tempProofImage=null; updateProofBox(); }
    });
  });

  // Modal background click-to-close (PIN modal or proof modal, whichever is open)
  const modalBg = app.querySelector('.modal-bg');
  if(modalBg){ modalBg.addEventListener('click', (e)=>{ if(e.target===modalBg){ state.showPinModal=false; state.viewingProofId=null; render(); } }); }
  const pinInput = document.getElementById('pin-input');
  if(pinInput){ pinInput.addEventListener('keydown', e=>{ if(e.key==='Enter') submitPin(); }); }

  // Proof upload field (transaction form)
  attachProofBoxHandlers();

  // Filters (riwayat / kelola)
  app.querySelectorAll('[data-filter]').forEach(el=>{
    const evt = el.tagName==='SELECT' ? 'change' : 'input';
    el.addEventListener(evt, ()=>{
      const key = el.getAttribute('data-filter');
      state.filters[key] = el.value;
      render();
      // restore focus for text search
      if(key==='search'){
        const again = document.querySelector('[data-filter="search"]');
        if(again){ again.focus(); again.selectionStart = again.selectionEnd = again.value.length; }
      }
    });
  });

  // Transaction form
  const txForm = document.getElementById('tx-form');
  if(txForm){
    const accSel = document.getElementById('f-account');
    const typeSel = document.getElementById('f-type');
    const refreshCats = ()=>{
      const catSel = document.getElementById('f-category');
      const cats = CATEGORIES[accSel.value][typeSel.value];
      catSel.innerHTML = cats.map(c=>`<option value="${c}">${c}</option>`).join('');
    };
    accSel.addEventListener('change', refreshCats);
    typeSel.addEventListener('change', refreshCats);
    txForm.addEventListener('submit', (e)=>{
      e.preventDefault();
      const fd = new FormData(txForm);
      const tx = {
        id: state.editingId || uid(),
        date: fd.get('date'),
        account: fd.get('account'),
        type: fd.get('type'),
        category: fd.get('category'),
        amount: Number(fd.get('amount')),
        description: fd.get('description'),
        donor: fd.get('donor'),
        proofImage: state.tempProofImage || null,
        createdAt: Date.now()
      };
      if(state.editingId){
        const idx = state.transactions.findIndex(t=>t.id===state.editingId);
        state.transactions[idx] = tx;
      } else {
        state.transactions.push(tx);
      }
      persistTransactions();
      state.editingId = null;
      state.tempProofImage = null;
      state.view = 'admin-kelola';
      render();
      showToast('Transaksi berhasil disimpan.');
    });
  }

  // Settings form
  const settingsForm = document.getElementById('settings-form');
  if(settingsForm){
    settingsForm.addEventListener('submit', (e)=>{
      e.preventDefault();
      const fd = new FormData(settingsForm);
      state.settings.mosqueName = fd.get('mosqueName') || state.settings.mosqueName;
      state.settings.tagline = fd.get('tagline') || state.settings.tagline;
      state.settings.pembangunanTarget = Number(fd.get('pembangunanTarget'))||0;
      state.settings.accounts.bjb.number = fd.get('bjb_number');
      state.settings.accounts.bjb.holder = fd.get('bjb_holder');
      state.settings.accounts.muamalat.number = fd.get('muamalat_number');
      state.settings.accounts.muamalat.holder = fd.get('muamalat_holder');
      const newPin = fd.get('adminPin');
      if(newPin && newPin.trim()) state.settings.adminPin = newPin.trim();
      persistSettings();
      render();
      showToast('Pengaturan berhasil disimpan.');
    });
  }

  // Report filters
  const repAcc = document.getElementById('rep-account');
  const repMonth = document.getElementById('rep-month');
  const repYear = document.getElementById('rep-year');
  if(repAcc){ repAcc.addEventListener('change', ()=>{ state.reportFilters.account = repAcc.value; render(); }); }
  if(repMonth){ repMonth.addEventListener('change', ()=>{ state.reportFilters.month = Number(repMonth.value); render(); }); }
  if(repYear){ repYear.addEventListener('change', ()=>{ state.reportFilters.year = Number(repYear.value); render(); }); }

  // CSV import
  const csvFile = document.getElementById('csv-file');
  if(csvFile){
    csvFile.addEventListener('change', (e)=>{
      const file = e.target.files[0];
      if(!file) return;
      const reader = new FileReader();
      reader.onload = (evt)=>{ parseCsv(evt.target.result); };
      reader.readAsText(file);
    });
  }
}

/* ---- Bukti transaksi: kompresi & attach handler tanpa render ulang form ---- */
function attachProofBoxHandlers(){
  const box = document.getElementById('proof-upload-container');
  if(!box) return;
  const fileInput = document.getElementById('proof-file');
  if(fileInput){
    fileInput.addEventListener('change', async (e)=>{
      const file = e.target.files[0];
      if(!file) return;
      if(!file.type.startsWith('image/')){ showToast('File harus berupa gambar.'); return; }
      try{
        const dataUrl = await compressImageFile(file, 1000, 0.62);
        state.tempProofImage = dataUrl;
        updateProofBox();
      }catch(err){ showToast('Gagal memproses gambar. Coba file lain.'); }
    });
  }
  const removeBtn = box.querySelector('[data-action="remove-proof"]');
  if(removeBtn){ removeBtn.addEventListener('click', ()=>{ state.tempProofImage=null; updateProofBox(); }); }
}
function updateProofBox(){
  const box = document.getElementById('proof-upload-container');
  if(!box) return;
  box.innerHTML = renderProofUploadBox();
  attachProofBoxHandlers();
}
function compressImageFile(file, maxDim, quality){
  return new Promise((resolve, reject)=>{
    const reader = new FileReader();
    reader.onerror = reject;
    reader.onload = ()=>{
      const img = new Image();
      img.onerror = reject;
      img.onload = ()=>{
        let {width, height} = img;
        if(width > maxDim || height > maxDim){
          if(width >= height){ height = Math.round(height * (maxDim/width)); width = maxDim; }
          else { width = Math.round(width * (maxDim/height)); height = maxDim; }
        }
        const canvas = document.createElement('canvas');
        canvas.width = width; canvas.height = height;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#FFFFFF';
        ctx.fillRect(0,0,width,height);
        ctx.drawImage(img, 0, 0, width, height);
        resolve(canvas.toDataURL('image/jpeg', quality));
      };
      img.src = reader.result;
    };
    reader.readAsDataURL(file);
  });
}

function submitPin(){
  const input = document.getElementById('pin-input');
  const val = input ? input.value : '';
  if(val === state.settings.adminPin){
    state.isAdmin = true;
