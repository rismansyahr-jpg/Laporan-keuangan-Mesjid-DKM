    state.pinError = '';
    state.view = 'admin-input';
    render();
    showToast('Berhasil masuk sebagai Admin.');
  } else {
    state.pinError = 'PIN salah. Silakan coba lagi.';
    state.pinInput = val;
    render();
    const again = document.getElementById('pin-input');
    if(again) again.focus();
  }
}

